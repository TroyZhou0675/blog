---
import Base from './Base.astro';

interface Props {
  title: string;
  date: string;
  category?: string;
  tags?: string[];
  excerpt?: string;
  cover?: string;
  activeNav?: string;
  readingTime?: number;
}

const { title, date, category, tags = [], excerpt, cover, activeNav, readingTime: minutes } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Base title={title} description={excerpt} activeNav={activeNav}>

  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/blog/">博客</a>
        <span class="sep">/</span>
        {category && <span>{category}</span>}
      </nav>
    </div>
  </div>

  <article>
    <header class="article-header">
      <h1 class="article-title">{title}</h1>
      <div class="article-meta">
        <span class="article-meta-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {formattedDate}
        </span>
        {category && <span class="article-meta-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          {category}
        </span>}
        {minutes && (
          <span class="article-meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            约 {minutes} 分钟阅读
          </span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="article-tags" style="margin-top: 1rem; display: flex; gap: .5rem; flex-wrap: wrap;">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    {cover && (
      <div class="article-cover">
        <img src={cover} alt={title} loading="lazy" />
      </div>
    )}

    <div class="article-body">
      <slot />
    </div>

    <div class="comments-container">
      <script
        src="https://utteranc.es/client.js"
        repo="TroyZhou0675/BlogComments"
        issue-term="pathname"
        label="comment"
        theme="github-light"
        crossorigin="anonymous"
        async>
      </script>
    </div>
  </article>

  <style>
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-size: .875rem;
      color: var(--text-faint);
    }
    .breadcrumb a { color: var(--text-muted); }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb .sep { color: var(--text-faint); }
    .comments-container {
      max-width: 760px;
      margin: 0 auto var(--space-16);
      padding: 0 var(--space-6);
    }
  </style>

</Base>
