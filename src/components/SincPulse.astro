---
// Sinc RF Pulse decoration — nLobes=7, ±7π, 14 zero crossings
// variant: 'light' | 'dark' — defaults to 'light'
interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
const isDark = variant === 'dark';
---

<div class:list={["sinc-wrap", isDark ? "sinc-wrap--dark" : "sinc-wrap--light"]}>
  <svg
    viewBox={isDark ? "0 0 800 50" : "0 0 800 42"}
    xmlns="http://www.w3.org/2000/svg"
    style="display:block; width:100%; overflow:visible;"
    aria-label={isDark ? "sinc RF pulse waveform (dark)" : "sinc RF pulse waveform"}
    role="img"
  >
    <line
      x1="0" y1={isDark ? 44 : 36} x2="800" y2={isDark ? 44 : 36}
      stroke={isDark ? "#5A4535" : "#D8CFC4"}
      stroke-width="1"
    />
    <path
      id={isDark ? "sinc-dark" : "sinc-main"}
      d={isDark ? "M 0,44 L 800,44" : "M 0,36 L 800,36"}
      fill="none"
      stroke={isDark ? "#E8B4A0" : "#C4846A"}
      stroke-width={isDark ? "1.7" : "1.5"}
      opacity={isDark ? "0.9" : "0.85"}
    />
  </svg>
</div>

<script is:inline>
  function sincPath(cx, yP, yB, w, lobes, pts) {
    var half = w / 2, total = (2 * lobes + 1) * pts + 1, r = [];
    for (var i = 0; i < total; i++) {
      var t = i / (total - 1), x = (cx - half) + t * w;
      var u = ((x - cx) / half) * lobes * Math.PI;
      var s = Math.abs(u) < 1e-9 ? 1 : Math.sin(u) / u;
      r.push({ x: x, y: yB - s * (yB - yP) });
    }
    return r;
  }
  function buildPath(pts, l, r, y) {
    var d = ['M ' + l + ',' + y, 'L ' + pts[0].x.toFixed(1) + ',' + pts[0].y.toFixed(2)];
    for (var i = 1; i < pts.length; i++) {
      var p = pts[i - 1], c = pts[i], mx = (p.x + c.x) / 2;
      d.push('C ' + mx.toFixed(1) + ',' + p.y.toFixed(2) + ' ' + mx.toFixed(1) + ',' + c.y.toFixed(2) + ' ' + c.x.toFixed(1) + ',' + c.y.toFixed(2));
    }
    d.push('L ' + r + ',' + pts[pts.length - 1].y.toFixed(2));
    return d.join(' ');
  }
  function drawSinc() {
    var main = document.getElementById('sinc-main');
    var dark = document.getElementById('sinc-dark');
    if (main) main.setAttribute('d', buildPath(sincPath(400, 14, 36, 340, 7, 22), 0, 800, 36));
    if (dark) dark.setAttribute('d', buildPath(sincPath(400, 14, 44, 340, 7, 22), 0, 800, 44));
  }
  drawSinc();
  document.addEventListener('astro:after-swap', drawSinc);
</script>

<style>
  .sinc-wrap {
    border-radius: 12px;
    padding: 1.5rem 1.5rem 0.75rem;
    margin: 1.5rem 0;
  }
  .sinc-wrap--light {
    background: #FFFDF9;
    border: 1px solid #E0D5C8;
  }
  .sinc-wrap--dark {
    background: #2E1F14;
  }


  #sinc-main, #sinc-dark {
    stroke-dasharray: 4000;
    stroke-dashoffset: 4000;
    animation: sinc-draw 2.8s ease-out forwards;
  }
  @keyframes sinc-draw {
    from { stroke-dashoffset: 4000; opacity: 0; }
    8%   { opacity: 1; }
    to   { stroke-dashoffset: 0; opacity: 1; }
  }
</style>
