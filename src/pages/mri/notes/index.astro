---
import Base from '../../../layouts/Base.astro';
import { mriNotes } from '../../../data/mri.js';
---

<Base title="MRI学习笔记" activeNav="mri">

  <div class="page-header">
    <div class="container">
      <nav style="display:flex; gap:.5rem; font-size:.875rem; color:var(--text-faint); margin-bottom:1rem;">
        <a href="/mri/" style="color:var(--text-muted)">MRI专区</a>
        <span>/</span>
        <span>学习笔记</span>
      </nav>
      <h1 class="page-title">学习笔记</h1>
      <p class="page-subtitle">系统整理MRI原理、序列与影像分析方法</p>
    </div>
  </div>

  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <div class="post-list">
        {mriNotes.map(note => (
          <article class="post-item animate-in">
            <div>
              <div class="post-item-meta">
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;vertical-align:middle;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {new Date(note.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="card-meta-dot"></span>
                <span class="tag tag--mri" style="font-size:.7rem;">笔记</span>
              </div>
              <a href={`/mri/notes/${note.slug}/`} style="text-decoration:none;">
                <h2 class="post-item-title">{note.title}</h2>
              </a>
              <p class="post-item-excerpt">{note.excerpt}</p>
              <div style="display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.5rem;">
                {note.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <div class="post-item-aside">
              <span class="post-views">{note.views.toLocaleString()}</span>
              <span class="post-views-label">阅读</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Base>
