---
import Base from '../../layouts/Base.astro';
import SincPulse from '../../components/SincPulse.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const mriNotes = allNotes
  .filter(n => n.slug.startsWith('mri/'))
  .sort((a, b) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  });
---

<Base title="MRI专区" activeNav="mri">

  <div class="page-header">
    <div class="container">
      <h1 class="page-title">MRI 专区</h1>
      <p class="page-subtitle">系统整理MRI学习笔记与实验日志，欢迎一起探讨</p>
    </div>
  </div>

  <div class="container" style="padding-top: 0;">
    <SincPulse />
  </div>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">

      <div class="section-header" style="margin-bottom: 2rem;">
        <h2 class="section-title">学习笔记</h2>
        <a href="/notes/" class="section-link">
          查看全部
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      {mriNotes.length > 0 ? (
        <div class="card-grid stagger-children" style="margin-bottom: 3rem;">
          {mriNotes.slice(0, 6).map(note => (
            <a href={`/notes/${note.slug}/`} class="card" style="text-decoration:none;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <span class="tag tag--mri">📝 笔记</span>
                <span style="font-size: .75rem; color: var(--text-faint);">
                  {note.data.date ? new Date(note.data.date).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' }) : ''}
                </span>
              </div>
              <h3 class="card-title" style="margin-top: .5rem;">{note.data.title}</h3>
              {note.data.excerpt && <p class="card-excerpt">{note.data.excerpt}</p>}
            </a>
          ))}
        </div>
      ) : (
        <p style="color: var(--text-muted); text-align: center; padding: 2rem 0;">暂无笔记内容</p>
      )}

    </div>
  </section>

</Base>
