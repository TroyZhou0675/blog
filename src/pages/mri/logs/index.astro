---
import Base from '../../../layouts/Base.astro';
---

<Base title="实验日志" activeNav="mri">

  <div class="page-header">
    <div class="container">
      <nav style="display:flex; gap:.5rem; font-size:.875rem; color:var(--text-faint); margin-bottom:1rem;">
        <a href="/mri/" style="color:var(--text-muted)">MRI专区</a>
        <span>/</span>
        <span>实验日志</span>
      </nav>
      <h1 class="page-title">实验日志</h1>
      <p class="page-subtitle">记录真实的实验过程、数据处理和踩坑经验</p>
    </div>
  </div>

  <section class="section" style="padding-top: 2rem;">
    <div class="container" style="text-align: center; padding: 5rem 1.5rem;">
      <div style="font-size: 3rem; margin-bottom: 1.5rem;">🧪</div>
      <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--primary-deep); margin-bottom: .75rem;">
        实验日志即将上线
      </h3>
      <p style="color: var(--text-muted); font-size: .9rem; max-width: 400px; margin: 0 auto 2rem;">
        在浙大影像实验室的实验记录、数据处理流程和踩坑经验，会在完成后第一时间整理发布。
      </p>
      <a href="/mri/notes/" style="display: inline-flex; align-items: center; gap: .5rem; background: var(--primary); color: var(--bg); padding: .6rem 1.5rem; border-radius: var(--radius-full); font-size: .9rem; text-decoration: none;">
        ← 先去看学习笔记
      </a>
    </div>
  </section>

</Base>
