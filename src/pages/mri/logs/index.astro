---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const logs = allNotes
  .filter(n => n.data.category === 'MRI / 实验日志')
  .sort((a, b) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  });
---

<Base title="实验日志" activeNav="mri">

  <div class="page-header">
    <div class="container">
      <nav style="display:flex; gap:.5rem; font-size:.875rem; color:var(--text-faint); margin-bottom:1rem;">
        <a href="/mri/" style="color:var(--text-muted)">MRI专区</a>
        <span>/</span>
        <span>实验日志</span>
      </nav>
      <h1 class="page-title">实验日志</h1>
      <p class="page-subtitle">记录真实的实验过程、数据处理和踩坑经验</p>
    </div>
  </div>

  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      {logs.length > 0 ? (
        <div class="post-list">
          {logs.map(note => (
            <article class="post-item animate-in">
              <div>
                <div class="post-item-meta">
                  {note.data.date && (
                    <>
                      <span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;vertical-align:middle;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {new Date(note.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                      </span>
                      <span class="card-meta-dot"></span>
                    </>
                  )}
                  <span class="tag tag--log" style="font-size:.7rem;">实验日志</span>
                </div>
                <a href={`/notes/${note.slug}/`} style="text-decoration:none;">
                  <h2 class="post-item-title">{note.data.title}</h2>
                </a>
                {note.data.excerpt && <p class="post-item-excerpt">{note.data.excerpt}</p>}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div style="text-align: center; padding: 5rem 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1.5rem;">🧪</div>
          <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--primary-deep); margin-bottom: .75rem;">
            实验日志即将上线
          </h3>
          <p style="color: var(--text-muted); font-size: .9rem; max-width: 400px; margin: 0 auto 2rem;">
            在浙大影像实验室的实验记录、数据处理流程和踩坑经验，会在完成后第一时间整理发布。
          </p>
        </div>
      )}
    </div>
  </section>

</Base>
