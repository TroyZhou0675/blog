---
import Base from '../../../layouts/Base.astro';
import { mriLogs } from '../../../data/mri.js';
---

<Base title="实验日志" activeNav="mri">

  <div class="page-header">
    <div class="container">
      <nav style="display:flex; gap:.5rem; font-size:.875rem; color:var(--text-faint); margin-bottom:1rem;">
        <a href="/mri/" style="color:var(--text-muted)">MRI专区</a>
        <span>/</span>
        <span>实验日志</span>
      </nav>
      <h1 class="page-title">实验日志</h1>
      <p class="page-subtitle">记录真实的实验过程、数据处理和踩坑经验</p>
    </div>
  </div>

  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <div class="post-list">
        {mriLogs.map(log => (
          <article class="post-item animate-in">
            <div>
              <div class="post-item-meta">
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;vertical-align:middle;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {new Date(log.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="card-meta-dot"></span>
                <span class="tag tag--log" style="font-size:.7rem;">实验日志</span>
              </div>
              <a href={`/mri/logs/${log.slug}/`} style="text-decoration:none;">
                <h2 class="post-item-title">{log.title}</h2>
              </a>
              <p class="post-item-excerpt">{log.excerpt}</p>
              <div style="display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.5rem;">
                {log.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
              {log.images && log.images.length > 0 && (
                <div style="display:flex; gap:.5rem; margin-top:.75rem; flex-wrap:wrap;">
                  {log.images.map(img => (
                    <img src={img} alt="实验照片" style="width:80px; height:60px; object-fit:cover; border-radius:6px; border:1px solid var(--border);" loading="lazy" />
                  ))}
                </div>
              )}
            </div>
            <div class="post-item-aside">
              <span class="post-views">{log.views.toLocaleString()}</span>
              <span class="post-views-label">阅读</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Base>
