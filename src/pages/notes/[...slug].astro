---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map(note => {
    // slug is relative path under notes/, e.g. "mri/mri-basics/1-pulse-sequence"
    return {
      params: { slug: note.slug },
      props: { note },
    };
  });
}

const { note } = Astro.props;
const { Content } = await note.render();
const { title, date, category, excerpt } = note.data;
---
<Base title={title} description={excerpt} activeNav="notes">
  <div class="page-header">
    <div class="container">
      <nav style="display:flex; gap:.5rem; font-size:.875rem; color:var(--text-faint); margin-bottom:1rem;">
        <a href="/notes/" style="color:var(--text-muted)">课程笔记</a>
        <span>/</span>
        <span>{category}</span>
      </nav>
      <h1 class="page-title" style="font-size: 2rem;">{title}</h1>
      {date && (
        <p style="color: var(--text-faint); font-size: .875rem; margin-top: .5rem;">
          {new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      )}
    </div>
  </div>

  <div class="container" style="max-width: 900px; padding-top: 2rem; padding-bottom: 4rem;">
    <div class="article-body">
      <Content />
    </div>
  </div>
</Base>
