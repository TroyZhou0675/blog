---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  const sorted = notes.sort((a, b) => a.slug.localeCompare(b.slug));
  return sorted.map((note, i) => ({
    params: { slug: note.slug },
    props: {
      note,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { note, prev, next } = Astro.props;
const { Content, headings } = await note.render();
const { title, date, category, excerpt } = note.data;

// Astro's built-in headings from remark/rehype processing
const toc = (headings || []).filter(h => h.depth <= 3);
---
<Base title={title} description={excerpt} activeNav="notes">
  <div class="note-article">
    <!-- Article Header -->
    <div class="note-header">
      <div class="note-header-inner">
        <nav class="note-breadcrumb">
          <a href="/notes/">课程笔记</a>
          <span class="breadcrumb-sep">›</span>
          <span>{category}</span>
        </nav>
        <h1 class="note-title">{title}</h1>
        {date && (
          <p class="note-meta">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:4px;">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            {new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            <span class="note-meta-dot"></span>
            <span>{category}</span>
          </p>
        )}
      </div>
    </div>

    <!-- Two-column layout: TOC + Content -->
    <div class={`note-layout${toc.length === 0 ? ' no-toc' : ''}`}>
      {toc.length > 0 && (
        <aside class="note-toc-sidebar">
          <div class="note-toc">
            <div class="note-toc-title">目录</div>
            <ul class="note-toc-list">
              {toc.map(h => (
                <li class={`toc-item toc-h${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )}

      <!-- Article Content -->
      <div class="note-content">
        <div class="article-body">
          <Content />
        </div>

        <!-- Prev / Next Navigation -->
        <nav class="note-nav" aria-label="章节导航">
          <div class="note-nav-inner">
            {prev ? (
              <a class="note-nav-link note-nav-prev" href={`/notes/${prev.slug}/`}>
                <span class="note-nav-dir">← 上一章</span>
                <span class="note-nav-title">{prev.data.title}</span>
              </a>
            ) : <div />}

            {next ? (
              <a class="note-nav-link note-nav-next" href={`/notes/${next.slug}/`}>
                <span class="note-nav-dir">下一章 →</span>
                <span class="note-nav-title">{next.data.title}</span>
              </a>
            ) : <div />}
          </div>
        </nav>
      </div>
    </div>
  </div>
</Base>

<script>
  // Render Mermaid diagrams client-side
  import mermaid from 'mermaid';

  mermaid.initialize({
    startOnLoad: false,
    theme: 'neutral',
    fontFamily: 'var(--font-body)',
    securityLevel: 'loose',
  });

  async function renderMermaid() {
    const mermaidBlocks = document.querySelectorAll('pre.language-mermaid, pre[data-language="mermaid"]');
    if (mermaidBlocks.length === 0) return;

    for (const block of mermaidBlocks) {
      const code = block.querySelector('code');
      if (!code) continue;
      const content = code.textContent || '';
      const id = `mermaid-${Math.random().toString(36).slice(2)}`;

      try {
        const { svg } = await mermaid.render(id, content.trim());
        const wrapper = document.createElement('div');
        wrapper.className = 'mermaid-wrapper';
        wrapper.innerHTML = svg;
        block.parentNode?.replaceChild(wrapper, block);
      } catch (err) {
        console.warn('Mermaid render error:', err);
      }
    }
  }

  // TOC active link tracking
  function initTOC() {
    const tocLinks = document.querySelectorAll('.note-toc-list a');
    if (tocLinks.length === 0) return;

    const headingEls = Array.from(
      document.querySelectorAll('.article-body h2, .article-body h3, .article-body h4')
    );

    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = document.querySelector(`.note-toc-list a[href="#${id}"]`);
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('active'));
            link?.classList.add('active');
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );

    headingEls.forEach(el => observer.observe(el));
  }

  renderMermaid();
  initTOC();
</script>

<style>
  .note-article {
    min-height: 70vh;
  }

  /* Header — warm background with subtle border */
  .note-header {
    background: var(--bg-warm);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0 2rem;
  }

  .note-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* When TOC is absent, hide empty sidebar and make content full-width */
  .note-toc-sidebar:empty,
  .note-toc-sidebar .note-toc-list:empty {
    display: none;
  }

  .note-layout.no-toc {
    grid-template-columns: 1fr !important;
  }

  .note-layout.no-toc .note-toc-sidebar {
    display: none;
  }

  .note-layout.no-toc .note-content {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  /* Breadcrumb */
  .note-breadcrumb {
    font-size: .8rem;
    color: var(--text-faint);
    margin-bottom: .75rem;
    display: flex;
    align-items: center;
    gap: .25rem;
  }

  .note-breadcrumb a {
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .note-breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb-sep {
    color: var(--text-faint);
    opacity: .5;
  }

  /* Title */
  .note-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--primary-deep);
    line-height: 1.2;
    margin-bottom: .75rem;
    letter-spacing: -.5px;
  }

  /* Meta */
  .note-meta {
    font-size: .8rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
  }

  .note-meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-faint);
    flex-shrink: 0;
  }

  /* Two-column layout: TOC sidebar + content */
  .note-layout {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* TOC Sidebar */
  .note-toc-sidebar {
    position: sticky;
    top: 80px;
  }

  .note-toc {
    background: var(--bg-warm);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.25rem;
  }

  .note-toc-title {
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: .75rem;
    padding: 0 .25rem;
  }

  .note-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .note-toc-list a {
    font-size: .8rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition), background var(--transition);
    display: block;
    padding: .3rem .5rem;
    border-radius: 4px;
    border-left: 2px solid transparent;
    line-height: 1.4;
  }

  .note-toc-list a:hover {
    color: var(--accent);
    background: rgba(196, 132, 106, .08);
    border-left-color: var(--accent);
  }

  .note-toc-list a.active {
    color: var(--accent);
    font-weight: 500;
    border-left-color: var(--accent);
    background: rgba(196, 132, 106, .08);
  }

  /* h3 in TOC — indented */
  .toc-h3 a {
    padding-left: 1.25rem;
    font-size: .775rem;
  }

  /* Content area */
  .note-content {
    min-width: 0; /* prevent grid blowout */
  }

  /* Better h3/h4 spacing in article */
  .article-body h3 {
    font-size: 1.15rem;
    margin-top: 2.5rem;
    margin-bottom: .75rem;
    padding-bottom: .4rem;
    border-bottom: 1px solid var(--border);
  }

  .article-body h4 {
    font-size: 1rem;
    margin-top: 2rem;
    margin-bottom: .5rem;
    color: var(--secondary);
  }

  /* Strong/bold */
  .article-body strong {
    font-weight: 600;
    color: var(--primary-deep);
  }

  /* Horizontal rule */
  .article-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* Prev / Next Navigation */
  .note-nav {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .note-nav-inner {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .note-nav-link {
    display: flex;
    flex-direction: column;
    gap: .3rem;
    text-decoration: none;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-warm);
    transition: border-color var(--transition), background var(--transition);
    max-width: 48%;
  }

  .note-nav-link:hover {
    border-color: var(--accent);
    background: rgba(196, 132, 106, .05);
  }

  .note-nav-next {
    text-align: right;
    margin-left: auto;
  }

  .note-nav-dir {
    font-size: .75rem;
    color: var(--text-faint);
    font-weight: 500;
    letter-spacing: .5px;
  }

  .note-nav-title {
    font-size: .9rem;
    color: var(--primary);
    font-weight: 500;
    line-height: 1.4;
  }

  /* Responsive: hide TOC on small screens */
  @media (max-width: 900px) {
    .note-layout {
      grid-template-columns: 1fr;
    }
    .note-toc-sidebar {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .note-nav-link {
      max-width: 100%;
    }
    .note-nav-next {
      text-align: right;
    }
  }
</style>
