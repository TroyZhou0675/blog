---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map(note => {
    // slug is relative path under notes/, e.g. "mri/mri-basics/1-pulse-sequence"
    return {
      params: { slug: note.slug },
      props: { note },
    };
  });
}

const { note } = Astro.props;
const { Content } = await note.render();
const { title, date, category, excerpt } = note.data;
---
<Base title={title} description={excerpt} activeNav="notes">
  <div class="note-article">
    <!-- Article Header -->
    <div class="note-header">
      <div class="note-header-inner">
        <nav class="note-breadcrumb">
          <a href="/notes/">课程笔记</a>
          <span class="breadcrumb-sep">›</span>
          <span>{category}</span>
        </nav>
        <h1 class="note-title">{title}</h1>
        {date && (
          <p class="note-meta">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:4px;">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            {new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            <span class="note-meta-dot"></span>
            <span>{category}</span>
          </p>
        )}
      </div>
    </div>

    <!-- Article Content -->
    <div class="note-content">
      <div class="article-body">
        <Content />
      </div>
    </div>
  </div>
</Base>

<style>
  .note-article {
    min-height: 70vh;
  }

  /* Header — warm background with subtle border */
  .note-header {
    background: var(--bg-warm);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0 2rem;
  }

  .note-header-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Breadcrumb */
  .note-breadcrumb {
    font-size: .8rem;
    color: var(--text-faint);
    margin-bottom: .75rem;
    display: flex;
    align-items: center;
    gap: .25rem;
  }

  .note-breadcrumb a {
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .note-breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb-sep {
    color: var(--text-faint);
    opacity: .5;
  }

  /* Title */
  .note-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--primary-deep);
    line-height: 1.2;
    margin-bottom: .75rem;
    letter-spacing: -.5px;
  }

  /* Meta */
  .note-meta {
    font-size: .8rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
  }

  .note-meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-faint);
    flex-shrink: 0;
  }

  /* Content area */
  .note-content {
    max-width: 860px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  /* Better h3/h4 spacing in article */
  .article-body h3 {
    font-size: 1.15rem;
    margin-top: 2.5rem;
    margin-bottom: .75rem;
    padding-bottom: .4rem;
    border-bottom: 1px solid var(--border);
  }

  .article-body h4 {
    font-size: 1rem;
    margin-top: 2rem;
    margin-bottom: .5rem;
    color: var(--secondary);
  }

  /* Strong/bold */
  .article-body strong {
    font-weight: 600;
    color: var(--primary-deep);
  }

  /* Horizontal rule */
  .article-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
</style>
