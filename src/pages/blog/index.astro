---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const pinned = posts.filter(p => p.data.pinned);
const others = posts.filter(p => !p.data.pinned);
const sorted = [...pinned, ...others].sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Collect unique categories
const cats = ['全部', ...new Set(posts.map(p => p.data.category || '未分类'))];
---

<Base title="个人博客" activeNav="blog">

  <div class="page-header">
    <div class="container">
      <h1 class="page-title">个人博客</h1>
      <p class="page-subtitle">记录学习、思考与生活中的点滴 · 共 {posts.length} 篇</p>
    </div>
  </div>

  <section class="section" style="padding-top: 2rem;">
    <div class="container container--narrow">

      <!-- Filter Bar -->
      <div class="filter-bar" id="filter-bar">
        <span class="filter-label">分类：</span>
        {cats.map((cat, i) => (
          <button
            class={`filter-btn ${i === 0 ? 'active' : ''}`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
        <span style="margin-left: auto; font-size: .8rem; color: var(--text-faint);" id="post-count">
          {posts.length} 篇文章
        </span>
      </div>

      <!-- Post List -->
      <div class="post-list" id="post-list">
        {sorted.map(post => (
          <article
            class="post-item animate-in"
            data-category={post.data.category || '未分类'}
            data-date={post.data.date}
          >
            <div>
              {post.data.pinned && (
                <div style="margin-bottom: .5rem;">
                  <span class="tag" style="background: rgba(196,132,106,.15); color: var(--accent); border-color: var(--accent); font-size: .7rem;">置顶</span>
                </div>
              )}
              <a href={`/blog/${post.slug}/`} style="text-decoration:none;">
                <h2 class="post-item-title">{post.data.title}</h2>
              </a>
              <div class="post-item-meta">
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px; vertical-align: middle;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="card-meta-dot"></span>
                <span>{post.data.category}</span>
                <span class="card-meta-dot"></span>
                {post.data.tags?.slice(0, 2).map(tag => (
                  <span class="tag" style="font-size: .7rem; padding: 1px 8px;">{tag}</span>
                ))}
              </div>
              {post.data.excerpt && (
                <p class="post-item-excerpt">{post.data.excerpt}</p>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Empty State -->
      <div id="blog-empty" class="notes-empty" style="display:none; margin-top: 3rem; text-align: center;">
        <p style="color: var(--text-muted);">该分类下暂无文章</p>
      </div>

    </div>
  </section>

  <style>
    .post-item[data-hidden="true"] {
      display: none;
    }
    .notes-empty {
      text-align: center;
      padding: 3rem 1rem;
    }
  </style>

  <script>
    const filterBtns = document.querySelectorAll('[data-category]');
    const postList = document.getElementById('post-list');
    const postCount = document.getElementById('post-count');
    const blogEmpty = document.getElementById('blog-empty');
    let currentCategory = '全部';

    function filter() {
      const articles = postList?.querySelectorAll('.post-item');
      let visible = 0;
      articles?.forEach(article => {
        const cat = article.getAttribute('data-category') || '';
        const show = currentCategory === '全部' || cat === currentCategory;
        article.setAttribute('data-hidden', show ? 'false' : 'true');
        if (show) visible++;
      });
      if (postCount) postCount.textContent = `${visible} 篇文章`;
      if (blogEmpty) blogEmpty.style.display = visible === 0 ? 'block' : 'none';
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCategory = btn.getAttribute('data-category') || '全部';
        filter();
      });
    });
  </script>

</Base>
