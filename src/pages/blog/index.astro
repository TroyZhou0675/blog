---
import Base from '../../layouts/Base.astro';
import { posts, categories } from '../../data/posts.js';

const sortedPosts = [...posts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Base title="个人博客" activeNav="blog">

  <div class="page-header">
    <div class="container">
      <h1 class="page-title">个人博客</h1>
      <p class="page-subtitle">记录学习、思考与生活中的点滴 · 共 {posts.length} 篇</p>
    </div>
  </div>

  <section class="section" style="padding-top: 2rem;">
    <div class="container container--narrow">

      <!-- Filter Bar -->
      <div class="filter-bar" id="filter-bar">
        <span class="filter-label">分类：</span>
        {categories.map((cat, i) => (
          <button
            class={`filter-btn ${i === 0 ? 'active' : ''}`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
        <span style="margin-left: auto; font-size: .8rem; color: var(--text-faint);" id="post-count">
          {posts.length} 篇文章
        </span>
      </div>

      <!-- Sort -->
      <div style="display: flex; gap: 1rem; margin-bottom: 2rem; align-items: center;">
        <span style="font-size: .875rem; color: var(--text-muted);">排序：</span>
        <button class="filter-btn active" data-sort="date" id="sort-date">按时间</button>
        <button class="filter-btn" data-sort="views" id="sort-views">按浏览量</button>
      </div>

      <!-- Post List -->
      <div class="post-list" id="post-list">
        {sortedPosts.map(post => (
          <article class="post-item animate-in" data-category={post.category} data-views={post.views} data-date={post.date}>
            <div>
              {post.pinned && (
                <div style="margin-bottom: .5rem;">
                  <span class="tag" style="background: var(--accent-light); color: var(--primary-deep); border-color: var(--accent);">置顶</span>
                </div>
              )}
              <a href={`/blog/${post.slug}/`} style="text-decoration:none;">
                <h2 class="post-item-title">{post.title}</h2>
              </a>
              <div class="post-item-meta">
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px; vertical-align: middle;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {new Date(post.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="card-meta-dot"></span>
                <span>{post.category}</span>
                <span class="card-meta-dot"></span>
                {post.tags.slice(0, 2).map(tag => (
                  <span class="tag" style="font-size: .7rem; padding: 1px 8px;">{tag}</span>
                ))}
              </div>
              <p class="post-item-excerpt">{post.excerpt}</p>
            </div>
            <div class="post-item-aside">
              <span class="post-views">{post.views.toLocaleString()}</span>
              <span class="post-views-label">阅读</span>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <style>
    .post-item[data-hidden="true"] {
      display: none;
    }
  </style>

  <script>
    const filterBtns = document.querySelectorAll('[data-category]');
    const sortBtns = document.querySelectorAll('[data-sort]');
    const postList = document.getElementById('post-list');
    const postCount = document.getElementById('post-count');
    let currentCategory = '全部';
    let currentSort = 'date';

    function filterAndSort() {
      const articles = postList?.querySelectorAll('.post-item');
      let visible = 0;

      articles?.forEach(article => {
        const cat = article.getAttribute('data-category');
        const show = currentCategory === '全部' || cat === currentCategory;
        article.setAttribute('data-hidden', show ? 'false' : 'true');
        if (show) visible++;
      });

      // Sort
      const arr = Array.from(articles || []);
      const visibleArr = arr.filter(a => a.getAttribute('data-hidden') === 'false');
      visibleArr.sort((a, b) => {
        if (currentSort === 'views') {
          return parseInt(b.getAttribute('data-views') || '0') - parseInt(a.getAttribute('data-views') || '0');
        }
        return new Date(b.getAttribute('data-date') || '').getTime() - new Date(a.getAttribute('data-date') || '').getTime();
      });

      visibleArr.forEach(el => postList?.appendChild(el));

      if (postCount) postCount.textContent = `${visible} 篇文章`;
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCategory = btn.getAttribute('data-category') || '全部';
        filterAndSort();
      });
    });

    sortBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        sortBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentSort = btn.getAttribute('data-sort') || 'date';
        filterAndSort();
      });
    });
  </script>

</Base>
