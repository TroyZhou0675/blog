---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const latestNotes = [...allNotes]
  .sort((a, b) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  })
  .slice(0, 3);

const mriNotes = allNotes.filter(n => n.slug.startsWith('mri/'));
---

<Base title="首页" activeNav="home">

  <!-- Hero Card -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="profile-card">
          <div class="profile-photo">
            <img
              src="/images/photo.jpg"
              alt="TroyZhou的照片"
              loading="eager"
            />
          </div>
          <div class="profile-info">
            <h1 class="profile-name">TroyZhou</h1>
            <div class="profile-tags">
              <span class="profile-tag">浙江大学</span>
              <span class="profile-tag">生物医学工程</span>
              <span class="profile-tag">大二</span>
              <span class="profile-tag">MRI</span>
            </div>
            <p class="profile-bio">
              MRI序列设计与fMRI分析初学者，正在系统学习中。<br/>
              欢迎交流：troyzhou0675@gmail.com
            </p>
            <div class="profile-links">
              <a href="https://github.com/TroyZhou0675" class="profile-link" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                GitHub
              </a>
              <a href="/notes/" class="profile-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                浏览笔记
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Notes -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最近更新</h2>
        <a href="/notes/" class="section-link">
          查看全部
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="card-grid stagger-children">
        {latestNotes.map(note => (
          <a href={`/notes/${note.slug}/`} class="card" style="text-decoration:none">
            <div class="card-meta">
              {note.data.date && (
                <span>{new Date(note.data.date).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}</span>
              )}
              <span class="card-meta-dot"></span>
              <span>{note.data.category}</span>
            </div>
            <h3 class="card-title">{note.data.title}</h3>
            {note.data.excerpt && (
              <p class="card-excerpt">{note.data.excerpt}</p>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MRI Zone -->
  <section class="section" style="background: var(--bg-warm);">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">MRI 专区</h2>
        <a href="/mri/" class="section-link">
          进入专区
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
        <a href="/notes/?cat=mri" class="mri-zone-card mri-zone-card--notes" style="text-decoration:none">
          <span class="mri-zone-icon">📝</span>
          <div class="mri-zone-title">学习笔记</div>
          <p class="mri-zone-desc">
            从T1/T2基础到序列设计，记录学习MRI物理原理、
            影像分析方法的完整笔记。正在路上，持续更新。
          </p>
          <span class="mri-zone-count">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/></svg>
            {mriNotes.length}篇笔记
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">关于我</h2>
      </div>
      <div class="about-grid">
        <div>
          <p class="about-text">
            浙江大学大二学生，就读于生物医学工程专业。
            对 MRI 的成像原理和序列设计有持续的好奇心，
            还在系统学习的阶段。
          </p>
          <div class="about-divider"></div>
          <p class="about-text">
            在这个网站，我记录学习中的思考和踩过的坑，
            也分享一些日常——爵士鼓、爵士乐和旅行中的碎片。
            如果刚好有共鸣，欢迎交流。
          </p>
          <p class="about-text" style="margin-top: 1rem; font-size: 0.9rem; color: var(--text-faint);">
            联系方式：troyzhou0675@gmail.com
          </p>
        </div>
        <div class="about-stats">
          <div class="stat-card">
            <span class="stat-number">2</span>
            <span class="stat-label">年级</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">浙大</span>
            <span class="stat-label">生物医学工程</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">🎵</span>
            <span class="stat-label">爵士鼓</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">∞</span>
            <span class="stat-label">好奇心</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>
